# Option A (API privée Fleeti)
FLEETI_API_BASE=https://tracking.ci.fleeti.co/api-v2
FLEETI_LOGIN=your-login@example.com
FLEETI_PASSWORD='replace-with-private-password'
FLEETI_DEALER_ID=23241
FLEETI_LOCALE=fr

# Option B (API publique Fleeti)
FLEETI_PUBLIC_API_BASE=https://api.fleeti.co/v1
FLEETI_PUBLIC_API_KEY='replace-with-public-api-key'
# Info fournisseur (non utilisée par le code, gardée pour référence)
FLEETI_PUBLIC_API_USERNAME=ApiKey-Teliman-Logistic

PORT=8787
VITE_BACKEND_URL=https://api.telimanlogistique.com
ALLOWED_ORIGINS=https://teliman-tracking-fleeti.vercel.app,https://www.telimanlogistique.com
# Optional: comma-separated tracker ids to restrict the fleet scope
FLEETI_TRACKER_IDS=3487533,3487539,3488325,3488326,3511635,3537761,3537762,3537766
# Optional: require an internal API token on every /api request
REQUIRE_API_TOKEN=false
INTERNAL_API_TOKEN=replace-with-internal-token
CACHE_TTL_MS=60000
