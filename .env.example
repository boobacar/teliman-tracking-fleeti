# Option A (API privée Fleeti)
FLEETI_API_BASE=https://tracking.ci.fleeti.co/api-v2
FLEETI_LOGIN=your-login@example.com
FLEETI_PASSWORD='replace-with-private-password'
FLEETI_DEALER_ID=23241
FLEETI_LOCALE=fr

# Option B (API publique Fleeti)
FLEETI_PUBLIC_API_BASE=https://api.fleeti.co/v1
FLEETI_PUBLIC_API_KEY='replace-with-public-api-key'
# Info fournisseur (non utilisée par le code, gardée pour référence)
FLEETI_PUBLIC_API_USERNAME=ApiKey-Teliman-Logistic

PORT=8787
# Stockage persistant hors du dépôt Git pour éviter de perdre les BL/bons carburant pendant les déploiements.
TELIMAN_DATA_DIR=/home/lamine/teliman-data
TELIMAN_UPLOADS_DIR=/home/lamine/teliman-data/uploads
VITE_BACKEND_URL=https://api.telimanlogistique.com
ALLOWED_ORIGINS=https://teliman-tracking-fleeti.vercel.app,https://www.telimanlogistique.com
# Optionnel: laisser vide pour importer TOUS les trackers Fleeti. Renseigner seulement pour restreindre volontairement la flotte.
FLEETI_TRACKER_IDS=
# Pagination / chunking backend Fleeti
FLEETI_PAGE_SIZE=500
FLEETI_TRACKER_CHUNK_SIZE=100
# Optional: require an internal API token on every /api request
REQUIRE_API_TOKEN=false
INTERNAL_API_TOKEN=replace-with-internal-token
CACHE_TTL_MS=60000

# WhatsApp via Baileys — connexion par QR code WhatsApp Web, sans compte Meta/Twilio.
# La session est stockée hors Git dans TELIMAN_DATA_DIR pour survivre aux déploiements.
WHATSAPP_PROVIDER=baileys
WHATSAPP_NOTIFICATIONS_ENABLED=true
WHATSAPP_BAILEYS_AUTH_DIR=/home/lamine/teliman-data/whatsapp-auth
# Alternative officielle Meta Cloud API si besoin plus tard.
# WHATSAPP_PROVIDER=meta
# WHATSAPP_PHONE_NUMBER_ID=replace-with-meta-phone-number-id
# WHATSAPP_ACCESS_TOKEN=replace-with-meta-permanent-access-token
# WHATSAPP_API_VERSION=v20.0
